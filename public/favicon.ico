<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@700&display=swap');
    .favicon-text {
      font-family: 'Orbitron', sans-serif;
      font-weight: 700;
      font-style: normal;
      letter-spacing: -1px;
    }
  </style>

  <!-- Background circle -->
  <circle cx="50" cy="50" r="48" fill="#0B3C5D"/>

  <!-- Solventis initial -->
  <text x="50" y="60" className="favicon-text" fontSize="40" fill="white" text-anchor="middle">
    S
  </text>

  <!-- Subtle tech accent -->
  <path d="M20 70H80" stroke="white" strokeWidth="2" strokeLinecap="round"/>
</svg>